// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Category {
  id          String    @id
  name        String?
  slug        String?
  description String?
  createdAt   String?
  updatedAt   String?
  articles    Article[]
  
  @@map("category")
}

model Article {
  id          String    @id
  title       String?
  slug        String?
  excerpt     String?
  content     String?
  image       String?
  status      String?
  published   String?   // stored as "1" or "0" in database
  featured    String?   // stored as "1" or "0" in database
  views       String?
  createdAt   String?
  updatedAt   String?
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id])
  authorId    String?
  author      User?     @relation(fields: [authorId], references: [id])
  comments    Comment[]
  // tags        Tag[]     @relation("ArticleToTag") // Temporarily disabled
  accessLogs  AccessLog[]
  
  @@map("article")
}

model Tag {
  id       String    @id
  name     String?
  slug     String?
  // articles Article[] @relation("ArticleToTag") // Temporarily disabled
  
  @@map("tag")
}

model Comment {
  id        String   @id
  name      String?
  email     String?
  content   String?
  approved  String?  // stored as "1" or "0" in database
  createdAt String?
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")
  
  @@map("comment")
}

model User {
  id        String   @id
  email     String?
  name      String?
  password  String?
  roleId    String?
  role      Role?    @relation(fields: [roleId], references: [id])
  articles  Article[]
  accessLogs AccessLog[]
  createdAt String?
  updatedAt String?
  
  @@map("user")
}

model Role {
  id          String @id
  name        String?
  description String?
  permissions String?  // JSON stored as string
  users       User[]
  createdAt   String?
  updatedAt   String?
  
  @@map("role")
}

model AccessLog {
  id        String   @id
  ip        String?
  userAgent String?
  method    String?
  path      String?
  action    String?  // visit_home, visit_articles, view_article, etc.
  referrer  String?
  articleId String?  // Si es una visita a un artículo específico
  article   Article? @relation(fields: [articleId], references: [id])
  userId    String?  // Si el usuario está autenticado
  user      User?    @relation(fields: [userId], references: [id])
  createdAt String?
  
  @@index([ip])
  @@index([path])
  @@index([action])
  @@index([createdAt])
  @@map("accesslog")
}

