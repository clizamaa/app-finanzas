# Archivo de ejemplo para variables de entorno en producción
# Copiar como .env.production en el servidor y completar con valores reales

# Base de datos MySQL en cPanel
DATABASE_URL="mysql://dmvadcrp_admin:xv=BUI0_tqX9@localhost:3306/dmvadcrp_app-finanzas"

# NextAuth - Generar secret seguro
NEXTAUTH_SECRET="generar_secret_muy_seguro_aqui_64_caracteres_minimo"
NEXTAUTH_URL="https://appfinanzashoy.com"

# JWT Secret - Generar secret diferente
JWT_SECRET="generar_jwt_secret_diferente_aqui_64_caracteres_minimo"

# Configuración del sitio
SITE_URL="https://appfinanzashoy.com"
SITE_NAME="AppFinanzasHoy"

# Entorno de producción
NODE_ENV="production"

# Puerto (cPanel lo asigna automáticamente)
# PORT se configura automáticamente en cPanel

# Configuraciones adicionales para producción
NEXT_TELEMETRY_DISABLED=1

# Instrucciones:
# 1. Crear base de datos MySQL en cPanel
# 2. Generar secrets seguros usando: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 3. Reemplazar todos los valores de ejemplo
# 4. Guardar como .env.production en el servidor
# 5. NUNCA subir este archivo a repositorios públicos